{
  "name": "dxf-crosshair-remover",
  "version": "1.0.0",
  "description": "Remove hole crosshairs and convert bulge-polylines to CIRCLE in Tekla/Advance Steel DXF files",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/oooargon/dxf-crosshair-remover.git"
  },
  "homepage": "https://github.com/oooargon/dxf-crosshair-remover",
  "bugs": {
    "url": "https://github.com/oooargon/dxf-crosshair-remover/issues"
  },
  "scripts": {
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:exe": "node scripts/build-exe.mjs",
    "build": "npm run build:bundle && npm run build:exe",
    "typecheck": "tsc --noEmit",
    "process": "tsx src/main.ts process",
    "remove-crosses": "tsx src/main.ts remove-crosses",
    "to-circles": "tsx src/main.ts to-circles",
    "analyze": "tsx src/main.ts analyze"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "caxa": "^3.0.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
